{
  "name": "opportunity-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create opportunity-radar-db",
    "db:schema": "wrangler d1 execute opportunity-radar-db --file=./schema.sql",
    "db:seed": "wrangler d1 execute opportunity-radar-db --file=./seed.sql",
    "db:schema:remote": "wrangler d1 execute opportunity-radar-db --remote --file=./schema.sql",
    "db:seed:remote": "wrangler d1 execute opportunity-radar-db --remote --file=./seed.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "typescript": "^5.4.0",
    "@cloudflare/workers-types": "^4.20250101.0"
  }
}
